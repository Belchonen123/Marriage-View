# Copy to .env.local and fill with real values (never commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

LIVEKIT_URL=wss://YOUR_LIVEKIT_HOST
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Comma-separated emails allowed to use /admin (must match signed-in user or identity email).
ADMIN_EMAILS=you@example.com,ops@example.com

# Optional: comma-separated auth user UUIDs (break-glass / OAuth without email). Checked before ADMIN_EMAILS.
# ADMIN_USER_IDS=00000000-0000-4000-8000-000000000000

# Ignored for access in production builds. Only NODE_ENV=development (e.g. `next dev`) relaxes admin to any signed-in user.
# ADMIN_RELAXED_AUTH=

# Production: https://your-domain.com — used for email digest links and absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Web Push (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron: GET /api/cron/email-digest with Authorization: Bearer <this value>
# On Vercel, set CRON_SECRET in Project Env; scheduled crons send this header automatically.
CRON_SECRET=

# Optional: Resend (https://resend.com) for email digest + urgent post-call alerts
RESEND_API_KEY=
RESEND_FROM="Nexus <onboarding@yourdomain.com>"
# Post-call safety: in-app mailto in the reflection modal; optional team inbox when Resend is configured
NEXT_PUBLIC_SUPPORT_EMAIL=
SUPPORT_ALERT_EMAIL=

# Optional: OpenAI for /coach (https://platform.openai.com/api-keys) — never commit real keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional: Azure OpenAI or compatible proxy base URL (default https://api.openai.com/v1)
# OPENAI_BASE_URL=
